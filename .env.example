CITYCOUNCIL_DATABASE_URL=postgresql+asyncpg://citycouncil:citycouncil@localhost:5433/citycouncil
CITYCOUNCIL_ELMS_API_BASE=https://api.chicityclerkelms.chicago.gov
# Live poll: optional page size / offset for GET /meeting
# CITYCOUNCIL_ELMS_POLL_TOP=100
# CITYCOUNCIL_ELMS_POLL_SKIP=0
# After the list response, fetch detail + matters + votes (many HTTP calls; use caps)
# CITYCOUNCIL_ELMS_ENRICH_DETAIL=0
# CITYCOUNCIL_ELMS_ENRICH_MAX_MEETINGS=3
# CITYCOUNCIL_ELMS_ENRICH_MAX_AGENDA_ITEMS=50
# CITYCOUNCIL_ELMS_ENRICH_CONCURRENCY=4
# sync-documents: PDF downloads per run (see docs/TICKETS.md)
# CITYCOUNCIL_DOCUMENTS_SYNC_MAX_MEETINGS=50
# CITYCOUNCIL_DOCUMENTS_MAX_BYTES=52428800
# CITYCOUNCIL_DOCUMENTS_HTTP_TIMEOUT=120
# CITYCOUNCIL_DOCUMENTS_SYNC_PDF_ONLY=1
# Optional: save each downloaded PDF under {sha256}.pdf (DOC-004)
# CITYCOUNCIL_DOCUMENTS_LOCAL_DIR=/var/lib/citycouncil/pdfs
# extract-documents (PyMuPDF chunks)
# CITYCOUNCIL_EXTRACT_MAX_DOCUMENTS=25
# CITYCOUNCIL_EXTRACT_MAX_CHARS_PER_CHUNK=4000
# CITYCOUNCIL_EMBEDDING_DIMENSIONS=512
# embed-run (LLM-203): Hugging Face Inference feature-extraction (see README).
# CITYCOUNCIL_HUGGINGFACE_TOKEN=
# CITYCOUNCIL_HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# CITYCOUNCIL_EMBEDDING_DIMENSIONS=384
# CITYCOUNCIL_HUGGINGFACE_INFERENCE_BASE_URL=https://router.huggingface.co/hf-inference
# RAG /search/chunks and optional query-vs-document prompts
# CITYCOUNCIL_HUGGINGFACE_SEARCH_PROMPT_NAME=query
# CITYCOUNCIL_SEARCH_DEFAULT_LIMIT=10
# CITYCOUNCIL_SEARCH_CHUNK_PREVIEW_CHARS=400
# GET /activity: default row limit and window when since= omitted
# CITYCOUNCIL_ACTIVITY_DEFAULT_LIMIT=50
# CITYCOUNCIL_ACTIVITY_MAX_LIMIT=200
# CITYCOUNCIL_ACTIVITY_DEFAULT_SINCE_DAYS=7
# CITYCOUNCIL_ACTIVITY_Q_MAX_CHARS=500
# CITYCOUNCIL_PUBLIC_BASE_URL=http://127.0.0.1:8000
# LLM-202 summarize (HF chat; needs chat-capable model on the router)
# CITYCOUNCIL_HUGGINGFACE_CHAT_MODEL=HuggingFaceTB/SmolLM2-360M-Instruct
# CITYCOUNCIL_LLM_SUMMARIZE_PROMPT_VERSION=1
# Optional override for GET /search/chunks disclaimer text
# CITYCOUNCIL_SEARCH_TRUST_DISCLAIMER=Verify all information against official records.
# OCR (extract-documents): requires `tesseract` on PATH
# CITYCOUNCIL_EXTRACT_OCR_ENABLED=1
# CITYCOUNCIL_EXTRACT_OCR_DPI=150
# CITYCOUNCIL_EMBED_ENQUEUE_LIMIT=100
# CITYCOUNCIL_EMBED_PROCESS_LIMIT=50
# CITYCOUNCIL_EMBED_BATCH_SIZE=20
# CITYCOUNCIL_EMBED_INPUT_MAX_CHARS=12000
# Demo without hitting the network:
CITYCOUNCIL_POLLER_USE_FIXTURE=1
CITYCOUNCIL_POLLER_FIXTURE_PATH=fixtures/sample_elms_response.json

# Required to use POST/GET /admin/* (X-Admin-Key or Authorization: Bearer). If unset, admin returns 503.
# CITYCOUNCIL_ADMIN_API_KEY=change-me-in-production
